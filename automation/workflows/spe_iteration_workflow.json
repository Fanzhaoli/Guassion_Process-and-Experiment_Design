{
  "workflow": {
    "name": "SPE实验设计自动化迭代",
    "version": "1.0.0",
    "description": "基于golutra多Agent协作的SPE实验设计空间优化workflow",
    "project_root": "E:/Github/Guassion_Process-and-Experiment_Design",
    "entry_command": "python -m automation.cli --profile research --name spe_auto_iteration",
    "auto_start": false
  },
  "agents": [
    {
      "id": "agent_design_space",
      "name": "实验设计空间探索Agent",
      "role": "design_explorer",
      "description": "负责生成和管理实验设计空间Ω=(P,T,W,M)，基于GP采集函数推荐下一轮采样点",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "python -c \"from automation.core.design_space import DesignSpace; ds = DesignSpace(); df = ds.generate_grid(); print(f'设计空间已生成: {len(df)} 个条件')\""
      ],
      "watch_output": true,
      "trigger_on": ["design_update", "gp_convergence"]
    },
    {
      "id": "agent_sequence_generator",
      "name": "实验序列生成Agent",
      "role": "sequence_generator",
      "description": "自动生成3×2×2混合设计实验序列，支持区组设计和拉丁方平衡",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "echo '实验序列生成器就绪'"
      ],
      "trigger_on": ["design_ready", "sequence_request"]
    },
    {
      "id": "agent_ddm_simulator",
      "name": "DDM仿真Agent",
      "role": "ddm_engine",
      "description": "运行DDM Euler仿真，生成带deadline和lapse omission的行为数据",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "echo 'DDM仿真引擎就绪'"
      ],
      "trigger_on": ["params_ready", "simulation_request"]
    },
    {
      "id": "agent_ez_estimator",
      "name": "模型参数估计Agent",
      "role": "parameter_estimator",
      "description": "使用EZ-Diffusion从行为数据反推DDM参数(v, a, t0)",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "python -c \"from automation.core.ez_diffusion import ez_diffusion; print('EZ-Diffusion估计器就绪')\""
      ],
      "trigger_on": ["data_ready", "estimation_request"]
    },
    {
      "id": "agent_gp_trainer",
      "name": "GP模型训练Agent",
      "role": "gp_trainer",
      "description": "训练GP模型学习Sigmoid残差，更新混合模型的GP层",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "echo 'GP训练器就绪'"
      ],
      "trigger_on": ["residuals_ready", "gp_retrain"]
    },
    {
      "id": "agent_effect_analyzer",
      "name": "效应量分析Agent",
      "role": "effect_analyzer",
      "description": "计算Cohen's d, G-power, BF01等效应量指标",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "echo '效应量分析器就绪'"
      ],
      "trigger_on": ["behavior_ready", "analysis_request"]
    },
    {
      "id": "agent_boundary_explorer",
      "name": "SPE边界探索Agent",
      "role": "boundary_explorer",
      "description": "识别SPE产生、增强或消失的设计边界条件",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "echo 'SPE边界探索器就绪'"
      ],
      "trigger_on": ["model_trained", "boundary_request"]
    },
    {
      "id": "agent_report_generator",
      "name": "报告生成Agent",
      "role": "report_generator",
      "description": "汇总所有结果，生成JSON/Markdown实验报告",
      "cli_tool": "python",
      "startup_commands": [
        "cd E:/Github/Guassion_Process-and-Experiment_Design",
        "echo '报告生成器就绪'"
      ],
      "trigger_on": ["analysis_complete", "report_request"]
    }
  ],
  "pipeline_stages": [
    {
      "stage": 1,
      "name": "设计空间初始化",
      "agent": "agent_design_space",
      "output": ["design_grid.csv", "design_lhs.csv"],
      "next_stage": 2
    },
    {
      "stage": 2,
      "name": "实验序列生成",
      "agent": "agent_sequence_generator",
      "input": ["design_grid.csv"],
      "output": ["experiment_sequence.csv"],
      "next_stage": 3
    },
    {
      "stage": 3,
      "name": "数据准备与模型训练",
      "agents": ["agent_ez_estimator", "agent_gp_trainer"],
      "input": ["experiment_sequence.csv", "EXP_data_combined.csv"],
      "output": ["trained_model.pkl"],
      "parallel": true,
      "next_stage": 4
    },
    {
      "stage": 4,
      "name": "数据生成与参数估计",
      "agents": ["agent_ddm_simulator", "agent_ez_estimator"],
      "input": ["design_grid.csv", "trained_model.pkl"],
      "output": ["synthetic_behavior_data.csv", "condition_params.csv"],
      "parallel": true,
      "next_stage": 5
    },
    {
      "stage": 5,
      "name": "效应量与边界分析",
      "agents": ["agent_effect_analyzer", "agent_boundary_explorer"],
      "input": ["synthetic_behavior_data.csv"],
      "output": ["effect_analysis.json", "boundary_exploration.csv"],
      "parallel": true,
      "next_stage": 6
    },
    {
      "stage": 6,
      "name": "报告生成",
      "agent": "agent_report_generator",
      "input": ["effect_analysis.json", "boundary_exploration.csv", "model_comparison.csv"],
      "output": ["final_report.json", "final_report.md"],
      "next_stage": "loop_back_to_1_or_end"
    }
  ],
  "iteration_loop": {
    "enabled": true,
    "max_rounds": 10,
    "convergence_criteria": {
      "gp_rmse_threshold": 0.01,
      "spe_stability_threshold": 0.005,
      "min_rounds": 3
    },
    "next_round_design_update": "agent_design_space"
  },
  "data_flow": {
    "experiment_params": "automation/output/design_grid.csv",
    "trial_sequence": "automation/output/experiment_sequence.csv",
    "synthetic_data": "automation/output/synthetic_behavior_data.csv",
    "ddm_params": "automation/output/condition_params.csv",
    "effect_metrics": "automation/output/effect_analysis.json",
    "final_report": "automation/output/final_report.json"
  },
  "skills": {
    "import_paths": [
      "automation/core/",
      "automation/workflows/"
    ]
  }
}
